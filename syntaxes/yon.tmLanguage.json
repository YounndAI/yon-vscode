{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "YON",
  "scopeName": "source.yon",
  "fileTypes": ["yon"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#block-json" },
    { "include": "#block-ts" },
    { "include": "#block-tsx" },
    { "include": "#block-js" },
    { "include": "#block-jsx" },
    { "include": "#block-css" },
    { "include": "#block-scss" },
    { "include": "#block-html" },
    { "include": "#block-md" },
    { "include": "#block-yaml" },
    { "include": "#block-toml" },
    { "include": "#block-xml" },
    { "include": "#block-sql" },
    { "include": "#block-graphql" },
    { "include": "#block-py" },
    { "include": "#block-rust" },
    { "include": "#block-go" },
    { "include": "#block-java" },
    { "include": "#block-kotlin" },
    { "include": "#block-swift" },
    { "include": "#block-c" },
    { "include": "#block-cpp" },
    { "include": "#block-csharp" },
    { "include": "#block-ruby" },
    { "include": "#block-php" },
    { "include": "#block-lua" },
    { "include": "#block-r" },
    { "include": "#block-bash" },
    { "include": "#block-ps1" },
    { "include": "#block-diff" },
    { "include": "#block-dockerfile" },
    { "include": "#block-terraform" },
    { "include": "#block-prisma" },
    { "include": "#block-proto" },
    { "include": "#block-svg" },
    { "include": "#block-csv" },
    { "include": "#block-yon" },
    { "include": "#block-fallback" },
    { "include": "#record" }
  ],
  "repository": {
    "comment": {
      "match": "^(#)(.*)$",
      "captures": {
        "1": { "name": "punctuation.definition.comment.yon" },
        "2": { "name": "comment.line.number-sign.yon" }
      }
    },

    "record": {
      "begin": "^\\s*(@[A-Z][A-Z0-9_]*)",
      "beginCaptures": {
        "1": { "name": "keyword.control.tag.yon" }
      },
      "end": "$",
      "patterns": [
        { "include": "#record-fields" }
      ]
    },

    "field": {
      "patterns": [
        { "include": "#field-typed" },
        { "include": "#field-plain" }
      ]
    },

    "field-typed": {
      "match": "([a-zA-Z_][a-zA-Z0-9_]*)(:)(str|bool|int|float|ts|ref|bytes|stream|vector)(=)",
      "captures": {
        "1": { "name": "variable.other.key.yon" },
        "2": { "name": "punctuation.separator.type.yon" },
        "3": { "name": "storage.type.yon" },
        "4": { "name": "keyword.operator.assignment.yon" }
      }
    },

    "field-plain": {
      "match": "([a-zA-Z_][a-zA-Z0-9_]*)(=)",
      "captures": {
        "1": { "name": "variable.other.key.yon" },
        "2": { "name": "keyword.operator.assignment.yon" }
      }
    },

    "pipe": {
      "match": "\\|",
      "name": "punctuation.separator.pipe.yon"
    },

    "string": {
      "begin": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.yon" } },
      "end": "\"",
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.yon" } },
      "name": "string.quoted.double.yon",
      "patterns": [
        {
          "match": "\\\\[\"\\\\nt]",
          "name": "constant.character.escape.yon"
        }
      ]
    },

    "list": {
      "begin": "\\[",
      "beginCaptures": { "0": { "name": "punctuation.definition.list.begin.yon" } },
      "end": "\\]",
      "endCaptures": { "0": { "name": "punctuation.definition.list.end.yon" } },
      "patterns": [
        { "include": "#arrow" },
        { "include": "#string" },
        { "include": "#field-typed" },
        { "include": "#field-plain" },
        { "include": "#reference-token" },
        { "include": "#bare-value" },
        {
          "match": ",",
          "name": "punctuation.separator.comma.yon"
        }
      ]
    },

    "arrow": {
      "match": "->",
      "name": "keyword.operator.arrow.yon"
    },

    "reference-token": {
      "match": "\\b(rid|block|ref|cfg|file|url|agent|group|role|caps|stream|id|loc|step|rule|check|turn|sess)(:)([A-Za-z0-9_./:@+#-]+)",
      "captures": {
        "1": { "name": "support.type.reference-prefix.yon" },
        "2": { "name": "punctuation.separator.reference.yon" },
        "3": { "name": "constant.other.reference.yon" }
      }
    },

    "level-value": {
      "match": "\\b(MUST_NOT|MUST|SHOULD|MAY|must_not|must|should|may)\\b",
      "name": "constant.language.level.yon"
    },

    "version-suffix": {
      "match": "@v[0-9]+",
      "name": "constant.numeric.version.yon"
    },

    "bare-value": {
      "match": "[A-Za-z0-9_./:@+#-]+",
      "name": "string.unquoted.yon"
    },

    "block-begin-fields": {
      "patterns": [
        { "include": "#pipe" },
        { "include": "#field" },
        { "include": "#string" },
        { "include": "#list" },
        { "include": "#reference-token" },
        { "include": "#level-value" },
        { "include": "#version-suffix" },
        { "include": "#bare-value" }
      ]
    },

    "record-fields": {
      "patterns": [
        { "include": "#pipe" },
        { "include": "#field" },
        { "include": "#string" },
        { "include": "#list" },
        { "include": "#arrow" },
        { "include": "#reference-token" },
        { "include": "#level-value" },
        { "include": "#version-suffix" },
        { "include": "#bare-value" }
      ]
    },

    "block-json": {
      "begin": "^\\s*(@BEGIN)\\s+(JSON(?:C|5)?|json(?:c|5)?|JSONL|jsonl|NDJSON|ndjson)(?:(#)([A-Za-z_][A-Za-z0-9_-]*)|(\\s.*))?$",
      "beginCaptures": {
        "1": { "name": "keyword.control.block.yon" },
        "2": { "name": "entity.name.tag.block.yon" },
        "3": { "name": "punctuation.separator.hash.yon" },
        "4": { "name": "entity.name.label.yon" },
        "5": { "patterns": [{ "include": "#block-begin-fields" }] }
      },
      "end": "^\\s*(@END)\\s+(JSON(?:C|5)?|json(?:c|5)?|JSONL|jsonl|NDJSON|ndjson)(.*)$",
      "endCaptures": {
        "1": { "name": "keyword.control.block.yon" },
        "2": { "name": "entity.name.tag.block.yon" },
        "3": { "patterns": [{ "include": "#block-begin-fields" }] }
      },
      "contentName": "meta.embedded.block.json.yon",
      "patterns": [{ "include": "source.json" }]
    },

    "block-ts": {
      "begin": "^\\s*(@BEGIN)\\s+(TS|ts)(?:(#)([A-Za-z_][A-Za-z0-9_-]*)|(\\s.*))?$",
